# ArgoCD connection
ARGOCD_URL=https://argocd.your-domain.com
ARGOCD_TOKEN=           # generate: argocd account generate-token --account <sa-name>

# Comma-separated label selectors (optional — omit to fetch all apps)
# e.g. app-type=frontend,app-type=backend
ARGOCD_LABEL_SELECTORS=

# Output mode: local | gws
OUTPUT_MODE=local

# ── local mode ──────────────────────────────────────────────────────────────
# Absolute path where the .xlsx will be written / updated.
LOCAL_OUTPUT_PATH=/data/argocd_apps.xlsx

# ── kubernetes (local development only) ─────────────────────────────────────
# Path to kubeconfig for kubectl exec. Not needed when running in-cluster.
KUBECONFIG=~/.kube/config

# ── business view ───────────────────────────────────────────────────────────
# Set BUSINESS_OUTPUT to also produce the pivoted customer cockpit sheet.
# Values: local | gws  (uses same credentials as the ops output)
BUSINESS_OUTPUT=

# Path for the business .xlsx (only used when BUSINESS_OUTPUT=local)
BUSINESS_OUTPUT_PATH=/data/argocd_business.xlsx

# ── gws mode ────────────────────────────────────────────────────────────────
# Spreadsheet ID from the Google Sheets URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=

# Path to the GCP service account JSON key file.
# generate key: gcloud iam service-accounts keys create key.json --iam-account=<sa>@<project>.iam.gserviceaccount.com
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/secrets/gws-credentials.json
