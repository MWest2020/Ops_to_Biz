# ArgoCD connection
ARGOCD_URL=https://argocd.your-domain.com
ARGOCD_TOKEN=           # generate: argocd account generate-token --account <sa-name>

# Comma-separated label selectors (optional — omit to fetch all apps)
# e.g. app-type=frontend,app-type=backend
ARGOCD_LABEL_SELECTORS=

# Output mode: local | gws
OUTPUT_MODE=local

# ── local mode ──────────────────────────────────────────────────────────────
# Absolute path where the .xlsx will be written / updated.
LOCAL_OUTPUT_PATH=output/argocd/argocd_apps.xlsx

# ── kubernetes (local development only) ─────────────────────────────────────
# Path to kubeconfig for kubectl exec. Not needed when running in-cluster.
KUBECONFIG=~/.kube/config

# ── business view ───────────────────────────────────────────────────────────
# Set BUSINESS_OUTPUT to also produce the pivoted customer cockpit sheet.
# Values: local | gws  (uses same credentials as the ops output)
BUSINESS_OUTPUT=

# Path for the business .xlsx (only used when BUSINESS_OUTPUT=local)
BUSINESS_OUTPUT_PATH=output/argocd/argocd_business.xlsx

# ── gws mode ────────────────────────────────────────────────────────────────
# Spreadsheet ID from the Google Sheets URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=

# Path to the GCP service account JSON key file.
# generate key: gcloud iam service-accounts keys create key.json --iam-account=<sa>@<project>.iam.gserviceaccount.com
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/secrets/gws-credentials.json

# ── ISO Audit pipeline ───────────────────────────────────────────────────────

# Miro API token (boards:read scope vereist)
# generate: Miro Dashboard → Profile → Apps → Create new app → OAuth scopes → boards:read
MIRO_API_TOKEN=

# Miro board ID voor auditnotities (uit de URL: miro.com/app/board/<BOARD_ID>/)
MIRO_BOARD_ID=uXjVJbKZEmw

# Google Drive map-ID voor "Interne Audits"
# (uit Drive-URL: drive.google.com/drive/folders/<FOLDER_ID>)
AUDIT_DRIVE_FOLDER_ID=

# Google Drive map-ID voor bronbestanden (procedures, beleid, werkinstructies)
# laat leeg om de volledige Drive te doorzoeken
AUDIT_SOURCE_FOLDER_ID=

# Google Sheets ID voor de auditmatrix (bevindingen)
# laat leeg om automatisch een nieuw Sheets-bestand aan te maken
AUDIT_SHEETS_ID=

# Google Docs template ID (wordt aangemaakt door setup-stap; vul in na eerste run)
AUDIT_TEMPLATE_DOC_ID=

# Standaard norm: 9001 | 27001 | beide
AUDIT_NORM=beide

# E-mailontvangers voor optionele Gmail-notificatie (kommagescheiden)
AUDIT_NOTIFICATIE_ONTVANGERS=

# Google Calendar ID voor audit-uitnodigingen (gebruik 'primary' voor hoofdkalender)
AUDIT_CALENDAR_ID=primary

# Lokale output-directory voor Markdown-rapporten (default: output/audit_reports/)
# Het rapport wordt altijd naar disk geschreven, ook zonder Drive-verbinding
LOCAL_REPORT_DIR=output/audit_reports

# ── Drive toegangsbeperking ──────────────────────────────────────────────────
# BELANGRIJK: deel het service account UITSLUITEND met de "Interne Audits"-map.
# Het service account heeft dan fysiek geen toegang tot andere Drive-bestanden.
# Stappen:
#   1. Open "Interne Audits" in Google Drive
#   2. Klik "Delen" → voeg het service account e-mailadres toe (Viewer + Editor)
#   3. Deel GEEN andere mappen of bestanden met dit account

GOOGLE_SERVICE_ACCOUNT_FILE=audit/config/service_account.json
  GOOGLE_IMPERSONATE_USER=markwesterweel@conduction.nl